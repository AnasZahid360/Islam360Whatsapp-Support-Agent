# LLM API Keys
# Choose one or both based on your preferred provider
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default Model Configuration
DEFAULT_MODEL_PROVIDER=openai  # Options: openai, anthropic
DEFAULT_MODEL_NAME=gpt-4o  # Options: gpt-4o, gpt-4o-mini, claude-3-5-sonnet-20241022

# RAG Configuration
RELEVANCE_THRESHOLD=0.7
MAX_RETRIEVED_DOCS=5
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name_here

# Memory Configuration
MAX_MESSAGES_BEFORE_SUMMARY=10
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Guardrails Configuration
ENABLE_HALLUCINATION_CHECK=true
MAX_HALLUCINATION_RETRIES=2
